{
    "name": "security-research",
    "description": "A plugin contains agents and skills for security research purpose",
    "version": "2.0.0",
    "author": {
        "name": "pucavv"
    },
    "lspServers": {
        "pyright": {
            "command": "pyright-langserver",
            "args": ["--stdio"],
            "extensionToLanguage": {
                ".py": "python",
                ".pyi": "python"
            }
        },
        "typescript": {
            "command": "typescript-language-server",
            "args": ["--stdio"],
            "extensionToLanguage": {
                ".ts": "typescript",
                ".tsx": "typescriptreact",
                ".js": "javascript",
                ".jsx": "javascriptreact",
                ".mts": "typescript",
                ".cts": "typescript",
                ".mjs": "javascript",
                ".cjs": "javascript"
            }
        },
        "gopls": {
            "command": "gopls",
            "extensionToLanguage": {
                ".go": "go"
            }
        },
        "clangd": {
            "command": "clangd",
            "args": ["--background-index"],
            "extensionToLanguage": {
                ".c": "c",
                ".h": "c",
                ".cpp": "cpp",
                ".cc": "cpp",
                ".cxx": "cpp",
                ".hpp": "cpp",
                ".hxx": "cpp",
                ".C": "cpp",
                ".H": "cpp"
            }
        },
        "rust-analyzer": {
            "command": "rust-analyzer",
            "extensionToLanguage": {
                ".rs": "rust"
            }
        },
        "ruby-lsp": {
            "command": "ruby-lsp",
            "extensionToLanguage": {
                ".rb": "ruby",
                ".rake": "ruby",
                ".gemspec": "ruby",
                ".ru": "ruby",
                ".erb": "erb"
            }
        },
        "jdtls": {
            "command": "jdtls",
            "extensionToLanguage": {
                ".java": "java"
            },
            "startupTimeout": 120000
        },
        "kotlin-lsp": {
            "command": "kotlin-lsp",
            "args": ["--stdio"],
            "extensionToLanguage": {
                ".kt": "kotlin",
                ".kts": "kotlin"
            },
            "startupTimeout": 120000
        },
        "intelephense": {
            "command": "intelephense",
            "args": ["--stdio"],
            "extensionToLanguage": {
                ".php": "php"
            }
        },
        "lua": {
            "command": "lua-language-server",
            "extensionToLanguage": {
                ".lua": "lua"
            }
        },
        "sourcekit-lsp": {
            "command": "sourcekit-lsp",
            "extensionToLanguage": {
                ".swift": "swift"
            }
        },
        "csharp-ls": {
            "command": "csharp-ls",
            "extensionToLanguage": {
                ".cs": "csharp"
            }
        }
    }
}